# Supabase — Next.js (browser-safe, publishable keys)
NEXT_PUBLIC_SUPABASE_URL=https://yourproject.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...       # Safe to expose — publishable key, RLS restricts access

# Supabase — Python pipeline (server-side only, never expose)
SUPABASE_URL=https://yourproject.supabase.co      # Same value as NEXT_PUBLIC_SUPABASE_URL — pipeline reads directly
SUPABASE_SERVICE_KEY=eyJ...                # NEVER prefix NEXT_PUBLIC_ — pipeline only, server-side only

# Pipeline APIs
GROQ_API_KEY=gsk_...
OPENAI_API_KEY=sk-...
PEXELS_API_KEY=...

# ─────────────────────────────────────────────────────────
# GitHub Actions: Repository Secrets
# Settings → Secrets and variables → Actions → New repository secret
# ─────────────────────────────────────────────────────────
# Add each of the following as a repository secret:
#
# SUPABASE_URL           = https://yfryhktlkbemzyequgds.supabase.co
# SUPABASE_SERVICE_KEY   = <service_role key from Supabase Dashboard → Settings → API>
# GROQ_API_KEY           = <from console.groq.com → API Keys>
# OPENAI_API_KEY         = <from platform.openai.com → API Keys>
# PEXELS_API_KEY         = <from www.pexels.com/api/new/>
